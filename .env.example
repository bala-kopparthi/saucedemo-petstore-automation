# =============================================================================
# `.env` itself is gitignored. `.env.example` IS committed.
# =============================================================================

# --- SauceDemo (Swag Labs) ---
BASE_URL=https://www.saucedemo.com

# --- Petstore Swagger API ---
API_BASE_URL=https://petstore.swagger.io/v2

# --- Test credentials ---
# SauceDemo creds are public (visible on their login page). Listed here to
# demonstrate the pattern of keeping creds out of source code.
SAUCEDEMO_VALID_USERNAME=standard_user
SAUCEDEMO_VALID_PASSWORD=secret_sauce

